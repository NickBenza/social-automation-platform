generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  settings      String?  @default("{}") // JSON as string for SQLite
  
  // Relations
  platforms     ConnectedPlatform[]
  voiceProfile  VoiceProfile?
  draftQueue    DraftQueue[]
  scheduledPosts ScheduledPost[]
  comments      CommentTracked[]
  trendReports  TrendReport[]
  analyticsReports AnalyticsReport[]
  agentAuditLogs AgentAuditLog[]
  agentSchedules AgentSchedule[]

  @@map("users")
}

model ConnectedPlatform {
  id                String   @id @default(cuid())
  userId            String
  platformName      String           // threads, x, linkedin, instagram, etc.
  mode              String           @default("OFF") // OFF, DRAFT_CRON, AUTOMATE
  
  // OAuth tokens (encrypted)
  oauthToken        String?          // AES-256-GCM encrypted
  refreshToken      String?          // AES-256-GCM encrypted
  tokenExpiresAt    DateTime?
  
  // Platform user info
  platformUserId    String?
  platformUsername  String?
  followerCount     Int?             @default(0)
  
  // Configuration
  config            String?          @default("{}") // JSON as string
  guardrails        String?          @default("{}") // JSON as string
  
  // Timestamps
  connectedAt       DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lastSyncAt        DateTime?
  
  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  drafts            DraftQueue[]
  scheduledPosts    ScheduledPost[]
  comments          CommentTracked[]
  
  @@unique([userId, platformName])
  @@map("connected_platforms")
}

model VoiceProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  profileJson     String   // Full voice profile as JSON string
  version         Int      @default(1)
  lastScannedAt   DateTime @default(now())
  samplePosts     String?  // Array of sample posts as JSON string
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("voice_profiles")
}

model DraftQueue {
  id                String   @id @default(cuid())
  userId            String
  platformId        String
  
  // Content
  contentText       String
  mediaSuggestions  String?  // JSON as string
  suggestedPostTime DateTime?
  hashtags          String   // Comma-separated or JSON array
  category          String   @default("ENGAGEMENT") // EDUCATIONAL, PROMOTIONAL, etc.
  confidenceScore   Float    @default(0.0) // 0-1
  
  // Status
  status            String   @default("PENDING") // PENDING, APPROVED, POSTED, DISMISSED
  createdByAgent    String   @default("content-generator")
  
  // Timestamps
  createdAt         DateTime @default(now())
  postedAt          DateTime?
  
  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          ConnectedPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  
  @@map("draft_queue")
}

model ScheduledPost {
  id                String   @id @default(cuid())
  userId            String
  platformId        String
  
  // Content
  contentText       String
  mediaUrl          String?
  
  // Scheduling
  scheduledTime     DateTime
  status            String   @default("QUEUED") // QUEUED, POSTED, FAILED, CANCELLED
  
  // Result
  postPlatformId    String?  // ID from the platform API after posting
  errorLog          String?
  
  // Timestamps
  createdAt         DateTime @default(now())
  postedAt          DateTime?
  
  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          ConnectedPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  
  @@map("scheduled_posts")
}

model CommentTracked {
  id                  String   @id @default(cuid())
  userId              String
  platformId          String
  
  // Platform IDs
  postPlatformId      String   // ID of the post on the platform
  commentPlatformId   String   // ID of the comment on the platform
  
  // Content
  authorName          String
  commentText         String
  
  // Analysis
  sentimentScore      Float?   // -1 to 1
  sentimentLabel      String   @default("NEUTRAL") // POSITIVE, NEUTRAL, NEGATIVE, HOSTILE
  intentClassification String  @default("OTHER") // QUESTION, COMPLIMENT, etc.
  priority            String   @default("LOW") // LOW, MEDIUM, HIGH, ESCALATE
  
  // Status
  status              String   @default("NEW") // NEW, REPLIED, FLAGGED, IGNORED
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // Relations
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform            ConnectedPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  replyQueue          ReplyQueue[]
  
  @@unique([platformId, commentPlatformId])
  @@map("comments_tracked")
}

model ReplyQueue {
  id                String   @id @default(cuid())
  commentId         String
  
  // Suggested content
  suggestedReplyText String
  
  // Mode
  mode              String   @default("SUGGESTION") // SUGGESTION, AUTO_POSTED
  status            String   @default("PENDING") // PENDING, APPROVED, POSTED, DISMISSED
  
  // Timestamps
  postedAt          DateTime?
  createdAt         DateTime @default(now())
  
  // Relations
  comment           CommentTracked @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  @@map("reply_queue")
}

model TrendReport {
  id          String   @id @default(cuid())
  userId      String
  reportJson  String   // Full trend report as JSON string
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("trend_reports")
}

model AnalyticsReport {
  id              String   @id @default(cuid())
  userId          String
  reportJson      String   // Full analytics report as JSON string
  dateRangeStart  DateTime
  dateRangeEnd    DateTime
  createdAt       DateTime @default(now())
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("analytics_reports")
}

model AgentAuditLog {
  id              String   @id @default(cuid())
  userId          String
  agentName       String   // content-generator, engagement-manager, etc
  actionType      String   // generate_post, reply_comment, etc
  platformName    String?
  contentSummary  String?
  status          String   @default("SUCCESS") // SUCCESS, FAILURE, SKIPPED, ESCALATED
  errorMessage    String?
  metadataJson    String?  // Additional context as JSON string
  createdAt       DateTime @default(now())
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("agent_audit_log")
}

model AgentSchedule {
  id                  String   @id @default(cuid())
  userId              String
  agentName           String
  cronExpression      String
  enabled             Boolean  @default(true)
  lastRunAt           DateTime?
  nextRunAt           DateTime?
  configOverridesJson String?  // Per-user agent config as JSON string
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, agentName])
  @@map("agent_schedules")
}